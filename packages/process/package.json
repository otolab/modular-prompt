{
  "name": "@modular-prompt/process",
  "version": "0.4.16",
  "description": "Process module for modular prompt framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules": {
      "types": "./dist/modules/index.d.ts",
      "import": "./dist/modules/index.js"
    },
    "./workflows": {
      "types": "./dist/workflows/index.d.ts",
      "import": "./dist/workflows/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b --force",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm build"
  },
  "dependencies": {
    "@modular-prompt/core": "workspace:*",
    "@modular-prompt/driver": "workspace:*",
    "@modular-prompt/utils": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "20.19.27",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitest/ui": "3.2.4",
    "eslint": "9.39.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/otolab/modular-prompt.git",
    "directory": "packages/process"
  },
  "keywords": [
    "prompt",
    "module",
    "ai",
    "llm",
    "process",
    "stream",
    "workflow"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
