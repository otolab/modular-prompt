{
  "name": "@modular-prompt/utils",
  "version": "0.3.3",
  "description": "Utility functions for modular-prompt",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm build"
  },
  "dependencies": {
    "@modular-prompt/core": "workspace:*",
    "js-yaml": "4.1.1",
    "jsonrepair": "3.13.1",
    "merge-stream": "2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.19.27",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "eslint": "9.39.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/otolab/modular-prompt.git",
    "directory": "packages/utils"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
